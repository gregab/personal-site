---
const title = "Traffic Jam";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />
		<title>{title}</title>
		<style>
			:root {
				--bg: #0f0f1a;
				--board: #1e1e32;
				--text: #e8e8e0;
			}

			* { margin: 0; padding: 0; box-sizing: border-box; }

			body {
				background: var(--bg);
				color: var(--text);
				font-family: 'Segoe UI', system-ui, sans-serif;
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				align-items: center;
				padding: 1rem;
				overflow-x: hidden;
				-webkit-user-select: none;
				user-select: none;
				touch-action: manipulation;
			}

			h1 { font-size: 1.5rem; margin-bottom: 0.25rem; }
			.moves-label { font-size: 0.9rem; color: #888; margin-bottom: 0.5rem; }

			#board-container {
				position: relative;
				width: min(90vw, 90vmin, 420px);
				height: min(90vw, 90vmin, 420px);
				margin: 0.25rem auto;
			}

			canvas {
				width: 100%;
				height: 100%;
				border-radius: 12px;
				display: block;
				touch-action: none;
			}

			.btn-row {
				display: flex;
				gap: 0.75rem;
				margin-top: 0.75rem;
				flex-wrap: wrap;
				justify-content: center;
			}

			button {
				background: #2a2a44;
				color: var(--text);
				border: 1px solid #3a3a5c;
				border-radius: 8px;
				padding: 0.6rem 1.2rem;
				font-size: 1rem;
				cursor: pointer;
				transition: background 0.15s, border-color 0.15s;
			}
			button:hover, button:active { background: #3a3a5c; border-color: #50507a; }

			#splash {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				min-height: 60vh;
			}
			#splash h1 { font-size: 2rem; margin-bottom: 0.5rem; }
			#splash .hello { font-size: 1.1rem; color: #999; margin-bottom: 1.5rem; }
			#splash button { font-size: 1.2rem; padding: 0.8rem 2rem; background: #c0392b; border-color: #e74c3c; }
			#splash button:hover { background: #e74c3c; }

			#game-area { display: none; flex-direction: column; align-items: center; }

			#win-overlay {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0,0,0,0.8);
				z-index: 100;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
			}
			#win-overlay.show { display: flex; }
			#win-overlay h2 { font-size: 1.8rem; margin-bottom: 0.4rem; }
			#win-overlay .stars { font-size: 2.5rem; margin-bottom: 0.4rem; }
			#win-overlay .msg { font-size: 1rem; color: #999; margin-bottom: 1rem; }
			#win-overlay button { font-size: 1.05rem; padding: 0.65rem 1.4rem; margin: 0.3rem; }

			#all-done {
				display: none;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				min-height: 60vh;
			}
			#all-done.show { display: flex; }
			#all-done h2 { font-size: 2rem; margin-bottom: 0.5rem; }
			#all-done .big-stars { font-size: 3rem; margin-bottom: 0.5rem; }
			#all-done .msg { font-size: 1.1rem; color: #999; margin-bottom: 1.5rem; max-width: 300px; }

			.confetti-canvas {
				position: fixed;
				inset: 0;
				pointer-events: none;
				z-index: 200;
			}
			a.back-link {
				color: #666;
				font-size: 0.85rem;
				margin-top: 1rem;
				text-decoration: none;
			}
			a.back-link:hover { color: #e8e8e0; }
		</style>
	</head>
	<body>
		<div id="splash">
			<div style="font-size:3rem; margin-bottom:0.5rem;">🚗</div>
			<h1>Traffic Jam</h1>
			<p class="hello">Slide blocks to get the red car out.</p>
			<button id="start-btn">Play</button>
		</div>

		<div id="game-area">
			<h1 id="level-title">Level 1</h1>
			<p class="moves-label">Moves: <span id="move-count">0</span></p>
			<div id="board-container">
				<canvas id="board"></canvas>
			</div>
			<div class="btn-row">
				<button id="reset-btn">Reset</button>
				<button id="menu-btn">Menu</button>
			</div>
		</div>

		<div id="win-overlay">
			<div class="stars" id="win-stars"></div>
			<h2 id="win-title">Solved!</h2>
			<p class="msg" id="win-msg"></p>
			<div class="btn-row">
				<button id="next-btn">Next Level</button>
				<button id="replay-btn">Retry</button>
			</div>
		</div>

		<div id="all-done">
			<div class="big-stars">🏆</div>
			<h2>All levels complete!</h2>
			<p class="msg">Nice work, Cam.</p>
			<button id="restart-all-btn">Play Again</button>
			<a class="back-link" href="/">← Back home</a>
		</div>

		<canvas id="confetti-canvas" class="confetti-canvas"></canvas>

		<script is:inline>
		(function() {
			// All levels verified solvable by BFS solver.
			// Minimum moves shown in comments.
			const LEVELS = [
				{
					// Minimum solution: 4 moves
					name: "Warm Up",
					pieces: [
						{ r:2, c:0, len:2, dir:'h', color:'#e74c3c' },
						{ r:1, c:5, len:2, dir:'v', color:'#3498db' },
						{ r:1, c:4, len:3, dir:'v', color:'#2ecc71' },
						{ r:5, c:0, len:3, dir:'h', color:'#e67e22' },
						{ r:0, c:3, len:3, dir:'v', color:'#9b59b6' },
					]
				},
				{
					// Minimum solution: 7 moves
					name: "Merge Lane",
					pieces: [
						{ r:2, c:0, len:2, dir:'h', color:'#e74c3c' },
						{ r:1, c:4, len:3, dir:'v', color:'#3498db' },
						{ r:3, c:1, len:3, dir:'v', color:'#2ecc71' },
						{ r:5, c:2, len:3, dir:'h', color:'#e67e22' },
						{ r:0, c:5, len:2, dir:'v', color:'#9b59b6' },
						{ r:1, c:3, len:2, dir:'v', color:'#1abc9c' },
						{ r:4, c:2, len:3, dir:'h', color:'#f39c12' },
					]
				},
				{
					// Minimum solution: 8 moves
					name: "Detour",
					pieces: [
						{ r:2, c:1, len:2, dir:'h', color:'#e74c3c' },
						{ r:1, c:1, len:3, dir:'h', color:'#3498db' },
						{ r:2, c:3, len:3, dir:'v', color:'#2ecc71' },
						{ r:0, c:4, len:3, dir:'v', color:'#e67e22' },
						{ r:4, c:4, len:2, dir:'h', color:'#9b59b6' },
						{ r:5, c:1, len:3, dir:'h', color:'#1abc9c' },
						{ r:1, c:0, len:3, dir:'v', color:'#f39c12' },
						{ r:0, c:1, len:2, dir:'h', color:'#e84393' },
					]
				},
				{
					// Minimum solution: 12 moves
					name: "Gridlock",
					pieces: [
						{ r:2, c:0, len:2, dir:'h', color:'#e74c3c' },
						{ r:2, c:2, len:2, dir:'v', color:'#3498db' },
						{ r:4, c:2, len:2, dir:'v', color:'#2ecc71' },
						{ r:1, c:4, len:3, dir:'v', color:'#e67e22' },
						{ r:0, c:1, len:2, dir:'h', color:'#9b59b6' },
						{ r:5, c:3, len:2, dir:'h', color:'#1abc9c' },
						{ r:1, c:5, len:2, dir:'v', color:'#f39c12' },
						{ r:4, c:3, len:2, dir:'h', color:'#e84393' },
						{ r:4, c:0, len:2, dir:'v', color:'#636e72' },
					]
				},
				{
					// Minimum solution: 15 moves
					name: "Rush Hour",
					pieces: [
						{ r:2, c:1, len:2, dir:'h', color:'#e74c3c' },
						{ r:3, c:0, len:2, dir:'h', color:'#3498db' },
						{ r:4, c:1, len:2, dir:'v', color:'#2ecc71' },
						{ r:0, c:5, len:3, dir:'v', color:'#e67e22' },
						{ r:5, c:2, len:2, dir:'h', color:'#9b59b6' },
						{ r:1, c:4, len:3, dir:'v', color:'#1abc9c' },
						{ r:0, c:3, len:2, dir:'v', color:'#f39c12' },
						{ r:4, c:3, len:3, dir:'h', color:'#e84393' },
						{ r:3, c:2, len:2, dir:'v', color:'#636e72' },
						{ r:0, c:0, len:3, dir:'v', color:'#fd79a8' },
					]
				},
				{
					// Minimum solution: 17 moves
					name: "Bottleneck",
					pieces: [
						{ r:2, c:2, len:2, dir:'h', color:'#e74c3c' },
						{ r:1, c:4, len:3, dir:'v', color:'#3498db' },
						{ r:0, c:5, len:2, dir:'v', color:'#2ecc71' },
						{ r:2, c:5, len:2, dir:'v', color:'#e67e22' },
						{ r:2, c:0, len:2, dir:'v', color:'#9b59b6' },
						{ r:1, c:0, len:3, dir:'h', color:'#1abc9c' },
						{ r:4, c:2, len:2, dir:'v', color:'#f39c12' },
						{ r:4, c:3, len:2, dir:'h', color:'#e84393' },
						{ r:2, c:1, len:3, dir:'v', color:'#636e72' },
						{ r:0, c:1, len:2, dir:'h', color:'#fd79a8' },
						{ r:5, c:3, len:2, dir:'h', color:'#00cec9' },
					]
				},
				{
					// Minimum solution: 21 moves
					name: "Pile Up",
					pieces: [
						{ r:2, c:0, len:2, dir:'h', color:'#e74c3c' },
						{ r:5, c:4, len:2, dir:'h', color:'#3498db' },
						{ r:4, c:3, len:2, dir:'h', color:'#2ecc71' },
						{ r:4, c:1, len:2, dir:'v', color:'#e67e22' },
						{ r:0, c:0, len:3, dir:'h', color:'#9b59b6' },
						{ r:3, c:2, len:2, dir:'v', color:'#1abc9c' },
						{ r:1, c:4, len:3, dir:'v', color:'#f39c12' },
						{ r:2, c:5, len:3, dir:'v', color:'#e84393' },
						{ r:1, c:0, len:2, dir:'h', color:'#636e72' },
						{ r:3, c:0, len:2, dir:'h', color:'#fd79a8' },
						{ r:1, c:3, len:2, dir:'v', color:'#00cec9' },
						{ r:4, c:0, len:2, dir:'v', color:'#a29bfe' },
					]
				},
				{
					// Minimum solution: 20 moves
					name: "Deadlock",
					pieces: [
						{ r:2, c:2, len:2, dir:'h', color:'#e74c3c' },
						{ r:5, c:0, len:2, dir:'h', color:'#3498db' },
						{ r:3, c:2, len:2, dir:'v', color:'#2ecc71' },
						{ r:1, c:1, len:3, dir:'v', color:'#e67e22' },
						{ r:4, c:3, len:3, dir:'h', color:'#9b59b6' },
						{ r:0, c:1, len:3, dir:'h', color:'#1abc9c' },
						{ r:2, c:0, len:3, dir:'v', color:'#f39c12' },
						{ r:0, c:0, len:2, dir:'v', color:'#e84393' },
						{ r:3, c:3, len:2, dir:'h', color:'#636e72' },
						{ r:5, c:3, len:2, dir:'h', color:'#fd79a8' },
						{ r:0, c:4, len:3, dir:'v', color:'#00cec9' },
						{ r:0, c:5, len:3, dir:'v', color:'#a29bfe' },
					]
				},
				{
					// Minimum solution: 24 moves
					name: "Freeway",
					pieces: [
						{ r:2, c:1, len:2, dir:'h', color:'#e74c3c' },
						{ r:2, c:4, len:2, dir:'v', color:'#3498db' },
						{ r:3, c:2, len:2, dir:'v', color:'#2ecc71' },
						{ r:5, c:1, len:2, dir:'h', color:'#e67e22' },
						{ r:0, c:1, len:3, dir:'h', color:'#9b59b6' },
						{ r:1, c:1, len:3, dir:'h', color:'#1abc9c' },
						{ r:0, c:5, len:2, dir:'v', color:'#f39c12' },
						{ r:4, c:5, len:2, dir:'v', color:'#e84393' },
						{ r:0, c:4, len:2, dir:'v', color:'#636e72' },
						{ r:4, c:3, len:2, dir:'h', color:'#fd79a8' },
						{ r:3, c:1, len:2, dir:'v', color:'#00cec9' },
						{ r:5, c:3, len:2, dir:'h', color:'#a29bfe' },
						{ r:1, c:0, len:2, dir:'v', color:'#fdcb6e' },
					]
				},
			];

			const GRID = 6;
			const canvas = document.getElementById('board');
			const ctx = canvas.getContext('2d');
			let cellSize, boardPx, padding;
			let pieces, currentLevel = 0, moves = 0;
			let dragging = null;
			let won = false;

			function sizeCanvas() {
				const container = document.getElementById('board-container');
				const w = container.clientWidth;
				const dpr = window.devicePixelRatio || 1;
				canvas.width = w * dpr;
				canvas.height = w * dpr;
				canvas.style.width = w + 'px';
				canvas.style.height = w + 'px';
				boardPx = w * dpr;
				padding = boardPx * 0.04;
				cellSize = (boardPx - padding * 2) / GRID;
			}

			function buildGrid() {
				const grid = Array.from({length: GRID}, () => Array(GRID).fill(-1));
				pieces.forEach((p, i) => {
					for (let s = 0; s < p.len; s++) {
						const rr = p.dir === 'v' ? p.r + s : p.r;
						const cc = p.dir === 'h' ? p.c + s : p.c;
						if (rr >= 0 && rr < GRID && cc >= 0 && cc < GRID) grid[rr][cc] = i;
					}
				});
				return grid;
			}

			function hexToRgb(hex) {
				return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
			}

			function draw() {
				const dpr = window.devicePixelRatio || 1;
				ctx.clearRect(0, 0, boardPx, boardPx);

				// Board background
				const bgGrad = ctx.createLinearGradient(0, 0, 0, boardPx);
				bgGrad.addColorStop(0, '#22223a');
				bgGrad.addColorStop(1, '#181828');
				ctx.fillStyle = bgGrad;
				ctx.beginPath();
				ctx.roundRect(0, 0, boardPx, boardPx, 14 * dpr);
				ctx.fill();

				// Board border
				ctx.strokeStyle = '#333355';
				ctx.lineWidth = 2 * dpr;
				ctx.beginPath();
				ctx.roundRect(0, 0, boardPx, boardPx, 14 * dpr);
				ctx.stroke();

				// Grid cells
				for (let r = 0; r < GRID; r++) {
					for (let c = 0; c < GRID; c++) {
						const x = padding + c * cellSize;
						const y = padding + r * cellSize;
						const inset = cellSize * 0.04;
						ctx.fillStyle = 'rgba(255,255,255,0.02)';
						ctx.beginPath();
						ctx.roundRect(x + inset, y + inset, cellSize - inset*2, cellSize - inset*2, 4 * dpr);
						ctx.fill();
					}
				}

				// Exit marker — glow + arrow on right side at row 2
				const exitY = padding + 2 * cellSize;
				const exitX = boardPx - padding;
				const glowGrad = ctx.createRadialGradient(exitX, exitY + cellSize*0.5, 0, exitX, exitY + cellSize*0.5, cellSize*0.8);
				glowGrad.addColorStop(0, 'rgba(231,76,60,0.25)');
				glowGrad.addColorStop(1, 'rgba(231,76,60,0)');
				ctx.fillStyle = glowGrad;
				ctx.fillRect(exitX - cellSize*0.5, exitY - cellSize*0.3, cellSize, cellSize*1.6);
				ctx.fillStyle = '#e74c3c';
				ctx.globalAlpha = 0.9;
				ctx.beginPath();
				ctx.moveTo(exitX - 2*dpr, exitY + cellSize*0.25);
				ctx.lineTo(exitX + padding*0.6, exitY + cellSize*0.5);
				ctx.lineTo(exitX - 2*dpr, exitY + cellSize*0.75);
				ctx.fill();
				ctx.globalAlpha = 1;

				// Pieces
				pieces.forEach((p, i) => {
					const x = padding + p.c * cellSize;
					const y = padding + p.r * cellSize;
					const w = p.dir === 'h' ? p.len * cellSize : cellSize;
					const h = p.dir === 'v' ? p.len * cellSize : cellSize;
					const gap = cellSize * 0.07;
					const rad = cellSize * 0.14;
					const [cr, cg, cb] = hexToRgb(p.color);

					// Shadow
					ctx.fillStyle = 'rgba(0,0,0,0.35)';
					ctx.beginPath();
					ctx.roundRect(x + gap + 2*dpr, y + gap + 3*dpr, w - gap*2, h - gap*2, rad);
					ctx.fill();

					// Body gradient
					const bodyGrad = p.dir === 'h'
						? ctx.createLinearGradient(x, y, x, y + h)
						: ctx.createLinearGradient(x, y, x + w, y);
					bodyGrad.addColorStop(0, `rgb(${Math.min(255,cr+30)},${Math.min(255,cg+30)},${Math.min(255,cb+30)})`);
					bodyGrad.addColorStop(1, p.color);
					ctx.fillStyle = bodyGrad;
					ctx.beginPath();
					ctx.roundRect(x + gap, y + gap, w - gap*2, h - gap*2, rad);
					ctx.fill();

					// Highlight
					ctx.fillStyle = 'rgba(255,255,255,0.15)';
					ctx.beginPath();
					ctx.roundRect(x + gap, y + gap, w - gap*2, (h - gap*2)*0.3, rad);
					ctx.fill();

					// Inner edge
					ctx.strokeStyle = `rgba(${Math.min(255,cr+60)},${Math.min(255,cg+60)},${Math.min(255,cb+60)},0.3)`;
					ctx.lineWidth = 1 * dpr;
					ctx.beginPath();
					ctx.roundRect(x + gap + 1*dpr, y + gap + 1*dpr, w - gap*2 - 2*dpr, h - gap*2 - 2*dpr, rad);
					ctx.stroke();

					// Wheels
					ctx.fillStyle = 'rgba(0,0,0,0.25)';
					if (p.dir === 'h') {
						const wy = y + h - gap - cellSize*0.12;
						for (let s = 0; s < p.len; s++) {
							const wx = x + gap + s*cellSize + cellSize*0.22;
							ctx.beginPath(); ctx.arc(wx, wy, cellSize*0.08, 0, Math.PI*2); ctx.fill();
							ctx.beginPath(); ctx.arc(wx + cellSize*0.38, wy, cellSize*0.08, 0, Math.PI*2); ctx.fill();
						}
					} else {
						const wx = x + w - gap - cellSize*0.12;
						for (let s = 0; s < p.len; s++) {
							const wy = y + gap + s*cellSize + cellSize*0.22;
							ctx.beginPath(); ctx.arc(wx, wy, cellSize*0.08, 0, Math.PI*2); ctx.fill();
							ctx.beginPath(); ctx.arc(wx, wy + cellSize*0.38, cellSize*0.08, 0, Math.PI*2); ctx.fill();
						}
					}

					// Windshield on hero car
					if (i === 0) {
						const wsX = x + w - gap - cellSize*0.45;
						const wsY = y + gap + cellSize*0.18;
						ctx.fillStyle = 'rgba(255,255,255,0.25)';
						ctx.beginPath();
						ctx.roundRect(wsX, wsY, cellSize*0.28, cellSize*0.48, 3*dpr);
						ctx.fill();
					}
				});
			}

			function getCell(px, py) {
				const rect = canvas.getBoundingClientRect();
				const dpr = window.devicePixelRatio || 1;
				const x = (px - rect.left) * dpr;
				const y = (py - rect.top) * dpr;
				return { row: Math.floor((y - padding) / cellSize), col: Math.floor((x - padding) / cellSize) };
			}

			function canMove(idx, newR, newC) {
				const p = pieces[idx];
				for (let s = 0; s < p.len; s++) {
					const rr = p.dir === 'v' ? newR + s : newR;
					const cc = p.dir === 'h' ? newC + s : newC;
					if (rr < 0 || rr >= GRID || cc < 0 || cc >= GRID) return false;
				}
				const grid = buildGrid();
				for (let s = 0; s < p.len; s++) {
					const rr = p.dir === 'v' ? newR + s : newR;
					const cc = p.dir === 'h' ? newC + s : newC;
					if (grid[rr][cc] !== -1 && grid[rr][cc] !== idx) return false;
				}
				return true;
			}

			function checkWin() {
				const hero = pieces[0];
				return hero.r === 2 && hero.c + hero.len >= GRID;
			}

			function onPointerDown(e) {
				if (won) return;
				e.preventDefault();
				const pt = e.touches ? e.touches[0] : e;
				const { row, col } = getCell(pt.clientX, pt.clientY);
				const grid = buildGrid();
				if (row < 0 || row >= GRID || col < 0 || col >= GRID) return;
				const idx = grid[row][col];
				if (idx === -1) return;
				dragging = { idx, startR: pieces[idx].r, startC: pieces[idx].c, startX: pt.clientX, startY: pt.clientY, moved: false };
			}

			function onPointerMove(e) {
				if (!dragging) return;
				e.preventDefault();
				const pt = e.touches ? e.touches[0] : e;
				const p = pieces[dragging.idx];
				const dx = pt.clientX - dragging.startX;
				const dy = pt.clientY - dragging.startY;
				const rect = canvas.getBoundingClientRect();
				const pxPerCell = rect.width / GRID;

				if (p.dir === 'h') {
					const cellDelta = Math.round(dx / (pxPerCell * 0.85));
					if (cellDelta !== 0) {
						let bestC = dragging.startC;
						const step = cellDelta > 0 ? 1 : -1;
						const target = dragging.startC + cellDelta;
						for (let c = dragging.startC + step; step > 0 ? c <= target : c >= target; c += step) {
							if (canMove(dragging.idx, p.r, c)) bestC = c; else break;
						}
						if (bestC !== p.c) { p.c = bestC; dragging.moved = true; draw(); }
					}
				} else {
					const cellDelta = Math.round(dy / (pxPerCell * 0.85));
					if (cellDelta !== 0) {
						let bestR = dragging.startR;
						const step = cellDelta > 0 ? 1 : -1;
						const target = dragging.startR + cellDelta;
						for (let r = dragging.startR + step; step > 0 ? r <= target : r >= target; r += step) {
							if (canMove(dragging.idx, r, p.c)) bestR = r; else break;
						}
						if (bestR !== p.r) { p.r = bestR; dragging.moved = true; draw(); }
					}
				}
			}

			function onPointerUp() {
				if (!dragging) return;
				if (dragging.moved) {
					moves++;
					document.getElementById('move-count').textContent = moves;
					if (checkWin()) { won = true; showWin(); }
				}
				dragging = null;
			}

			function showWin() {
				const starsEl = document.getElementById('win-stars');
				const titleEl = document.getElementById('win-title');
				const msgEl = document.getElementById('win-msg');
				const nextBtn = document.getElementById('next-btn');

				const titles = ["Solved!", "Nice.", "Clean.", "Smooth.", "Got it.", "Done.", "Nailed it.", "Sharp.", "Easy."];
				starsEl.textContent = moves <= 15 ? '⭐⭐⭐' : moves <= 30 ? '⭐⭐' : '⭐';
				titleEl.textContent = titles[currentLevel % titles.length];
				msgEl.textContent = `${moves} move${moves !== 1 ? 's' : ''}`;
				nextBtn.textContent = currentLevel >= LEVELS.length - 1 ? "Finish" : "Next Level";

				document.getElementById('win-overlay').classList.add('show');
				fireConfetti();
			}

			function loadLevel(idx) {
				currentLevel = idx;
				pieces = LEVELS[idx].pieces.map(p => ({...p}));
				moves = 0;
				won = false;
				document.getElementById('move-count').textContent = '0';
				document.getElementById('level-title').textContent = `Level ${idx + 1}: ${LEVELS[idx].name}`;
				document.getElementById('win-overlay').classList.remove('show');
				sizeCanvas();
				draw();
			}

			function fireConfetti() {
				const cc = document.getElementById('confetti-canvas');
				const cctx = cc.getContext('2d');
				const dpr = window.devicePixelRatio || 1;
				cc.width = window.innerWidth * dpr;
				cc.height = window.innerHeight * dpr;
				cc.style.width = window.innerWidth + 'px';
				cc.style.height = window.innerHeight + 'px';

				const colors = ['#e74c3c','#3498db','#2ecc71','#f1c40f','#9b59b6','#e67e22','#1abc9c','#fd79a8'];
				const particles = [];
				for (let i = 0; i < 100; i++) {
					particles.push({
						x: cc.width * Math.random(), y: -20 * dpr,
						vx: (Math.random()-0.5)*7*dpr, vy: Math.random()*4*dpr + 2*dpr,
						size: (Math.random()*5+3)*dpr,
						color: colors[Math.floor(Math.random()*colors.length)],
						rot: Math.random()*Math.PI*2, rv: (Math.random()-0.5)*0.2, life: 1
					});
				}
				let frame = 0;
				function animate() {
					cctx.clearRect(0, 0, cc.width, cc.height);
					let alive = false;
					particles.forEach(p => {
						if (p.life <= 0) return;
						alive = true;
						p.x += p.vx; p.vy += 0.12*dpr; p.y += p.vy;
						p.rot += p.rv; p.life -= 0.008;
						cctx.save();
						cctx.translate(p.x, p.y); cctx.rotate(p.rot);
						cctx.globalAlpha = Math.max(0, p.life);
						cctx.fillStyle = p.color;
						cctx.fillRect(-p.size/2, -p.size/2, p.size, p.size*0.6);
						cctx.restore();
					});
					if (alive && frame < 250) { frame++; requestAnimationFrame(animate); }
					else { cctx.clearRect(0, 0, cc.width, cc.height); }
				}
				animate();
			}

			canvas.addEventListener('mousedown', onPointerDown);
			canvas.addEventListener('mousemove', onPointerMove);
			canvas.addEventListener('mouseup', onPointerUp);
			canvas.addEventListener('mouseleave', onPointerUp);
			canvas.addEventListener('touchstart', onPointerDown, { passive: false });
			canvas.addEventListener('touchmove', onPointerMove, { passive: false });
			canvas.addEventListener('touchend', onPointerUp);

			document.getElementById('start-btn').addEventListener('click', () => {
				document.getElementById('splash').style.display = 'none';
				document.getElementById('game-area').style.display = 'flex';
				loadLevel(0);
			});
			document.getElementById('reset-btn').addEventListener('click', () => loadLevel(currentLevel));
			document.getElementById('menu-btn').addEventListener('click', () => {
				document.getElementById('game-area').style.display = 'none';
				document.getElementById('win-overlay').classList.remove('show');
				document.getElementById('splash').style.display = 'flex';
			});
			document.getElementById('next-btn').addEventListener('click', () => {
				if (currentLevel >= LEVELS.length - 1) {
					document.getElementById('win-overlay').classList.remove('show');
					document.getElementById('game-area').style.display = 'none';
					document.getElementById('all-done').classList.add('show');
					fireConfetti(); setTimeout(fireConfetti, 700);
				} else { loadLevel(currentLevel + 1); }
			});
			document.getElementById('replay-btn').addEventListener('click', () => loadLevel(currentLevel));
			document.getElementById('restart-all-btn').addEventListener('click', () => {
				document.getElementById('all-done').classList.remove('show');
				document.getElementById('game-area').style.display = 'flex';
				loadLevel(0);
			});
			window.addEventListener('resize', () => {
				if (document.getElementById('game-area').style.display !== 'none') { sizeCanvas(); draw(); }
			});
		})();
		</script>
	</body>
</html>
