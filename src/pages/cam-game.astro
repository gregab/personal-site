---
const title = "Cam's Puzzle Adventure!";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />
		<title>{title}</title>
		<style>
			:root {
				--bg: #1a1a2e;
				--board: #2d2d4a;
				--grid-line: #3a3a5c;
				--text: #e8e8e0;
				--star: #f1c40f;
			}

			* { margin: 0; padding: 0; box-sizing: border-box; }

			body {
				background: var(--bg);
				color: var(--text);
				font-family: 'Segoe UI', system-ui, sans-serif;
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				align-items: center;
				padding: 1rem;
				overflow-x: hidden;
				-webkit-user-select: none;
				user-select: none;
				touch-action: manipulation;
			}

			h1 { font-size: 1.5rem; margin-bottom: 0.25rem; }
			.level-label { font-size: 1rem; color: #aaa; margin-bottom: 0.5rem; }
			.moves-label { font-size: 0.9rem; color: #aaa; margin-bottom: 0.5rem; }

			#board-container {
				position: relative;
				width: min(90vw, 90vmin, 420px);
				height: min(90vw, 90vmin, 420px);
				margin: 0.25rem auto;
			}

			canvas {
				width: 100%;
				height: 100%;
				border-radius: 12px;
				display: block;
				touch-action: none;
			}

			.btn-row {
				display: flex;
				gap: 0.75rem;
				margin-top: 0.5rem;
				flex-wrap: wrap;
				justify-content: center;
			}

			button {
				background: #3a3a5c;
				color: var(--text);
				border: none;
				border-radius: 8px;
				padding: 0.6rem 1.2rem;
				font-size: 1rem;
				cursor: pointer;
				transition: background 0.15s;
			}
			button:hover, button:active { background: #50507a; }

			#splash {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				min-height: 60vh;
			}
			#splash h1 { font-size: 2rem; margin-bottom: 0.5rem; }
			#splash .hello { font-size: 1.3rem; color: #ccc; margin-bottom: 1.5rem; }
			#splash button { font-size: 1.2rem; padding: 0.8rem 2rem; background: #c0392b; }
			#splash button:hover { background: #e74c3c; }

			#game-area { display: none; flex-direction: column; align-items: center; }

			#win-overlay {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0,0,0,0.75);
				z-index: 100;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
			}
			#win-overlay.show { display: flex; }
			#win-overlay h2 { font-size: 2rem; margin-bottom: 0.5rem; }
			#win-overlay .stars { font-size: 3rem; margin-bottom: 0.5rem; }
			#win-overlay .msg { font-size: 1.1rem; color: #ccc; margin-bottom: 1rem; }
			#win-overlay button { font-size: 1.1rem; padding: 0.7rem 1.5rem; margin: 0.3rem; }

			#all-done {
				display: none;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				min-height: 60vh;
			}
			#all-done.show { display: flex; }
			#all-done h2 { font-size: 2.2rem; margin-bottom: 0.5rem; }
			#all-done .big-stars { font-size: 4rem; margin-bottom: 0.5rem; }
			#all-done .msg { font-size: 1.2rem; color: #ccc; margin-bottom: 1.5rem; max-width: 340px; }

			.confetti-canvas {
				position: fixed;
				inset: 0;
				pointer-events: none;
				z-index: 200;
			}
			a.back-link {
				color: #aaa;
				font-size: 0.85rem;
				margin-top: 1rem;
				text-decoration: none;
			}
			a.back-link:hover { color: #e8e8e0; }
		</style>
	</head>
	<body>
		<div id="splash">
			<div style="font-size:3rem; margin-bottom:0.5rem;">🚗</div>
			<h1>Traffic Jam!</h1>
			<p class="hello">Hi Cam! Can you help the red car escape?</p>
			<p style="color:#999; margin-bottom:1.5rem; max-width:300px; font-size:0.95rem;">
				Slide the blocks out of the way so the red car can drive to the exit!
			</p>
			<button id="start-btn">Let's Play!</button>
		</div>

		<div id="game-area">
			<h1 id="level-title">Level 1</h1>
			<p class="moves-label">Moves: <span id="move-count">0</span></p>
			<div id="board-container">
				<canvas id="board"></canvas>
			</div>
			<div class="btn-row">
				<button id="reset-btn">Start Over</button>
				<button id="menu-btn">Menu</button>
			</div>
		</div>

		<div id="win-overlay">
			<div class="stars" id="win-stars"></div>
			<h2 id="win-title">You did it!</h2>
			<p class="msg" id="win-msg"></p>
			<div class="btn-row">
				<button id="next-btn">Next Level</button>
				<button id="replay-btn">Play Again</button>
			</div>
		</div>

		<div id="all-done">
			<div class="big-stars">🌟🏆🌟</div>
			<h2>Amazing, Cam!</h2>
			<p class="msg">You solved every single puzzle! You're a superstar problem solver!</p>
			<button id="restart-all-btn">Play Again From Start</button>
			<a class="back-link" href="/">← Back home</a>
		</div>

		<canvas id="confetti-canvas" class="confetti-canvas"></canvas>

		<script is:inline>
		(function() {
			// ── LEVELS ──
			// Grid is 6x6. Each piece: [row, col, length, orientation, color, id]
			// orientation: 'h' = horizontal, 'v' = vertical
			// The FIRST piece (id=0) is always the red "hero" car, which must reach col=6 (right edge)
			// Hero car is always on row index specified, horizontal
			const LEVELS = [
				{
					name: "Warm Up",
					pieces: [
						{ r:2, c:1, len:2, dir:'h', color:'#e74c3c' },
						{ r:2, c:4, len:2, dir:'v', color:'#3498db' },
					]
				},
				{
					name: "Getting Started",
					pieces: [
						{ r:2, c:0, len:2, dir:'h', color:'#e74c3c' },
						{ r:0, c:2, len:3, dir:'v', color:'#3498db' },
						{ r:3, c:0, len:2, dir:'v', color:'#2ecc71' },
					]
				},
				{
					name: "Tricky!",
					pieces: [
						{ r:2, c:0, len:2, dir:'h', color:'#e74c3c' },
						{ r:0, c:2, len:3, dir:'v', color:'#3498db' },
						{ r:0, c:4, len:2, dir:'v', color:'#e67e22' },
						{ r:3, c:3, len:3, dir:'h', color:'#2ecc71' },
						{ r:4, c:0, len:2, dir:'h', color:'#9b59b6' },
					]
				},
				{
					name: "Think Ahead",
					pieces: [
						{ r:2, c:1, len:2, dir:'h', color:'#e74c3c' },
						{ r:0, c:0, len:2, dir:'v', color:'#1abc9c' },
						{ r:0, c:3, len:3, dir:'v', color:'#3498db' },
						{ r:0, c:5, len:2, dir:'v', color:'#e67e22' },
						{ r:3, c:1, len:2, dir:'v', color:'#9b59b6' },
						{ r:5, c:2, len:3, dir:'h', color:'#2ecc71' },
						{ r:3, c:4, len:3, dir:'v', color:'#f39c12' },
					]
				},
				{
					name: "Traffic Jam!",
					pieces: [
						{ r:2, c:0, len:2, dir:'h', color:'#e74c3c' },
						{ r:0, c:0, len:2, dir:'v', color:'#1abc9c' },
						{ r:0, c:2, len:2, dir:'h', color:'#e67e22' },
						{ r:0, c:4, len:2, dir:'v', color:'#f39c12' },
						{ r:1, c:2, len:2, dir:'v', color:'#3498db' },
						{ r:3, c:2, len:3, dir:'v', color:'#2ecc71' },
						{ r:3, c:0, len:2, dir:'h', color:'#9b59b6' },
						{ r:4, c:3, len:2, dir:'h', color:'#e84393' },
						{ r:5, c:4, len:2, dir:'h', color:'#fd79a8' },
						{ r:2, c:5, len:3, dir:'v', color:'#636e72' },
					]
				},
				{
					name: "Super Solver",
					pieces: [
						{ r:2, c:0, len:2, dir:'h', color:'#e74c3c' },
						{ r:0, c:0, len:2, dir:'h', color:'#1abc9c' },
						{ r:0, c:2, len:2, dir:'v', color:'#e67e22' },
						{ r:0, c:3, len:3, dir:'v', color:'#3498db' },
						{ r:1, c:4, len:2, dir:'h', color:'#f39c12' },
						{ r:3, c:0, len:3, dir:'v', color:'#9b59b6' },
						{ r:3, c:1, len:2, dir:'h', color:'#2ecc71' },
						{ r:4, c:2, len:2, dir:'v', color:'#e84393' },
						{ r:5, c:1, len:2, dir:'h', color:'#fd79a8' },
						{ r:3, c:4, len:2, dir:'v', color:'#636e72' },
						{ r:5, c:3, len:3, dir:'h', color:'#00cec9' },
						{ r:0, c:5, len:2, dir:'v', color:'#a29bfe' },
					]
				},
				{
					name: "Cam's Challenge",
					pieces: [
						{ r:2, c:1, len:2, dir:'h', color:'#e74c3c' },
						{ r:0, c:0, len:3, dir:'v', color:'#1abc9c' },
						{ r:0, c:1, len:2, dir:'h', color:'#e67e22' },
						{ r:0, c:3, len:2, dir:'v', color:'#3498db' },
						{ r:1, c:4, len:2, dir:'v', color:'#f39c12' },
						{ r:0, c:5, len:3, dir:'v', color:'#a29bfe' },
						{ r:3, c:1, len:3, dir:'v', color:'#9b59b6' },
						{ r:3, c:2, len:2, dir:'h', color:'#2ecc71' },
						{ r:4, c:3, len:2, dir:'v', color:'#e84393' },
						{ r:3, c:5, len:2, dir:'v', color:'#636e72' },
						{ r:5, c:2, len:3, dir:'h', color:'#fd79a8' },
						{ r:5, c:0, len:2, dir:'v', color:'#00cec9' },
						{ r:2, c:4, len:2, dir:'v', color:'#fdcb6e' },
					]
				},
			];

			const GRID = 6;
			const canvas = document.getElementById('board');
			const ctx = canvas.getContext('2d');
			let cellSize, boardPx, padding;
			let pieces, currentLevel = 0, moves = 0;
			let dragging = null; // { idx, startR, startC, startX, startY }
			let won = false;

			function sizeCanvas() {
				const container = document.getElementById('board-container');
				const w = container.clientWidth;
				const dpr = window.devicePixelRatio || 1;
				canvas.width = w * dpr;
				canvas.height = w * dpr;
				canvas.style.width = w + 'px';
				canvas.style.height = w + 'px';
				boardPx = w * dpr;
				padding = boardPx * 0.04;
				cellSize = (boardPx - padding * 2) / GRID;
			}

			function buildGrid() {
				const grid = Array.from({length: GRID}, () => Array(GRID).fill(-1));
				pieces.forEach((p, i) => {
					for (let s = 0; s < p.len; s++) {
						const rr = p.dir === 'v' ? p.r + s : p.r;
						const cc = p.dir === 'h' ? p.c + s : p.c;
						if (rr >= 0 && rr < GRID && cc >= 0 && cc < GRID) grid[rr][cc] = i;
					}
				});
				return grid;
			}

			function draw() {
				const dpr = window.devicePixelRatio || 1;
				ctx.clearRect(0, 0, boardPx, boardPx);

				// Board background
				ctx.fillStyle = '#2d2d4a';
				ctx.beginPath();
				ctx.roundRect(0, 0, boardPx, boardPx, 12 * dpr);
				ctx.fill();

				// Grid lines
				ctx.strokeStyle = '#3a3a5c';
				ctx.lineWidth = 1 * dpr;
				for (let i = 0; i <= GRID; i++) {
					const x = padding + i * cellSize;
					ctx.beginPath(); ctx.moveTo(x, padding); ctx.lineTo(x, boardPx - padding); ctx.stroke();
					ctx.beginPath(); ctx.moveTo(padding, x); ctx.lineTo(boardPx - padding, x); ctx.stroke();
				}

				// Exit marker (right side, row 2)
				const exitY = padding + 2 * cellSize;
				const exitX = boardPx - padding;
				ctx.fillStyle = '#e74c3c';
				ctx.beginPath();
				ctx.moveTo(exitX, exitY + cellSize * 0.2);
				ctx.lineTo(exitX + padding * 0.7, exitY + cellSize * 0.5);
				ctx.lineTo(exitX, exitY + cellSize * 0.8);
				ctx.fill();

				// Pieces
				pieces.forEach((p, i) => {
					const x = padding + p.c * cellSize;
					const y = padding + p.r * cellSize;
					const w = p.dir === 'h' ? p.len * cellSize : cellSize;
					const h = p.dir === 'v' ? p.len * cellSize : cellSize;
					const gap = cellSize * 0.06;
					const r = cellSize * 0.15;

					ctx.fillStyle = p.color;
					ctx.beginPath();
					ctx.roundRect(x + gap, y + gap, w - gap*2, h - gap*2, r);
					ctx.fill();

					// Highlight for 3D effect
					ctx.fillStyle = 'rgba(255,255,255,0.18)';
					ctx.beginPath();
					ctx.roundRect(x + gap, y + gap, w - gap*2, (h - gap*2) * 0.35, r);
					ctx.fill();

					// If hero car (i=0), draw a little car icon
					if (i === 0) {
						ctx.fillStyle = 'rgba(255,255,255,0.8)';
						ctx.font = `${cellSize * 0.45}px sans-serif`;
						ctx.textAlign = 'center';
						ctx.textBaseline = 'middle';
						ctx.fillText('🚗', x + w/2, y + h/2);
					}
				});
			}

			function getCell(px, py) {
				const rect = canvas.getBoundingClientRect();
				const dpr = window.devicePixelRatio || 1;
				const x = (px - rect.left) * dpr;
				const y = (py - rect.top) * dpr;
				const col = Math.floor((x - padding) / cellSize);
				const row = Math.floor((y - padding) / cellSize);
				return { row, col, x, y };
			}

			function canMove(idx, newR, newC) {
				const p = pieces[idx];
				// Bounds check
				for (let s = 0; s < p.len; s++) {
					const rr = p.dir === 'v' ? newR + s : newR;
					const cc = p.dir === 'h' ? newC + s : newC;
					if (rr < 0 || rr >= GRID || cc < 0 || cc >= GRID) return false;
				}
				// Collision check
				const grid = buildGrid();
				for (let s = 0; s < p.len; s++) {
					const rr = p.dir === 'v' ? newR + s : newR;
					const cc = p.dir === 'h' ? newC + s : newC;
					if (grid[rr][cc] !== -1 && grid[rr][cc] !== idx) return false;
				}
				return true;
			}

			function checkWin() {
				const hero = pieces[0];
				// Hero car (horizontal, row 2) reaches right edge: c + len >= GRID
				return hero.r === 2 && hero.c + hero.len >= GRID;
			}

			function onPointerDown(e) {
				if (won) return;
				e.preventDefault();
				const pt = e.touches ? e.touches[0] : e;
				const { row, col } = getCell(pt.clientX, pt.clientY);
				const grid = buildGrid();
				if (row < 0 || row >= GRID || col < 0 || col >= GRID) return;
				const idx = grid[row][col];
				if (idx === -1) return;
				dragging = {
					idx,
					startR: pieces[idx].r,
					startC: pieces[idx].c,
					startX: pt.clientX,
					startY: pt.clientY,
					moved: false
				};
			}

			function onPointerMove(e) {
				if (!dragging) return;
				e.preventDefault();
				const pt = e.touches ? e.touches[0] : e;
				const p = pieces[dragging.idx];
				const dx = pt.clientX - dragging.startX;
				const dy = pt.clientY - dragging.startY;
				const rect = canvas.getBoundingClientRect();
				const pxPerCell = rect.width / GRID; // approximate

				if (p.dir === 'h') {
					const cellDelta = Math.round(dx / (pxPerCell * 0.85));
					if (cellDelta !== 0) {
						const newC = dragging.startC + cellDelta;
						// Try to move as far as possible toward target
						let bestC = dragging.startC;
						const step = cellDelta > 0 ? 1 : -1;
						for (let c = dragging.startC + step; step > 0 ? c <= newC : c >= newC; c += step) {
							if (canMove(dragging.idx, p.r, c)) bestC = c;
							else break;
						}
						if (bestC !== p.c) {
							p.c = bestC;
							dragging.moved = true;
							draw();
						}
					}
				} else {
					const cellDelta = Math.round(dy / (pxPerCell * 0.85));
					if (cellDelta !== 0) {
						const newR = dragging.startR + cellDelta;
						let bestR = dragging.startR;
						const step = cellDelta > 0 ? 1 : -1;
						for (let r = dragging.startR + step; step > 0 ? r <= newR : r >= newR; r += step) {
							if (canMove(dragging.idx, r, p.c)) bestR = r;
							else break;
						}
						if (bestR !== p.r) {
							p.r = bestR;
							dragging.moved = true;
							draw();
						}
					}
				}
			}

			function onPointerUp(e) {
				if (!dragging) return;
				if (dragging.moved) {
					moves++;
					document.getElementById('move-count').textContent = moves;
					if (checkWin()) {
						won = true;
						showWin();
					}
				}
				dragging = null;
			}

			function showWin() {
				const overlay = document.getElementById('win-overlay');
				const starsEl = document.getElementById('win-stars');
				const titleEl = document.getElementById('win-title');
				const msgEl = document.getElementById('win-msg');
				const nextBtn = document.getElementById('next-btn');

				const cheers = [
					"Way to go, Cam!",
					"You're amazing, Cam!",
					"Brilliant thinking, Cam!",
					"Wow, Cam! So smart!",
					"Awesome job, Cam!",
					"You're a puzzle genius, Cam!",
					"Incredible, Cam!",
				];

				starsEl.textContent = moves <= 10 ? '⭐⭐⭐' : moves <= 20 ? '⭐⭐' : '⭐';
				titleEl.textContent = cheers[currentLevel % cheers.length];
				msgEl.textContent = `You solved "${LEVELS[currentLevel].name}" in ${moves} move${moves !== 1 ? 's' : ''}!`;

				if (currentLevel >= LEVELS.length - 1) {
					nextBtn.textContent = "🏆 See Final Score";
				} else {
					nextBtn.textContent = "Next Level →";
				}

				overlay.classList.add('show');
				fireConfetti();
			}

			function loadLevel(idx) {
				currentLevel = idx;
				pieces = LEVELS[idx].pieces.map(p => ({...p}));
				moves = 0;
				won = false;
				document.getElementById('move-count').textContent = '0';
				document.getElementById('level-title').textContent =
					`Level ${idx + 1}: ${LEVELS[idx].name}`;
				document.getElementById('win-overlay').classList.remove('show');
				sizeCanvas();
				draw();
			}

			// ── CONFETTI ──
			function fireConfetti() {
				const cc = document.getElementById('confetti-canvas');
				const cctx = cc.getContext('2d');
				cc.width = window.innerWidth * (window.devicePixelRatio || 1);
				cc.height = window.innerHeight * (window.devicePixelRatio || 1);
				cc.style.width = window.innerWidth + 'px';
				cc.style.height = window.innerHeight + 'px';

				const colors = ['#e74c3c','#3498db','#2ecc71','#f1c40f','#9b59b6','#e67e22','#1abc9c','#fd79a8'];
				const particles = [];
				const dpr = window.devicePixelRatio || 1;
				for (let i = 0; i < 120; i++) {
					particles.push({
						x: cc.width * Math.random(),
						y: -20 * dpr,
						vx: (Math.random() - 0.5) * 8 * dpr,
						vy: Math.random() * 4 * dpr + 2 * dpr,
						size: (Math.random() * 6 + 4) * dpr,
						color: colors[Math.floor(Math.random() * colors.length)],
						rot: Math.random() * Math.PI * 2,
						rv: (Math.random() - 0.5) * 0.2,
						life: 1
					});
				}
				let frame = 0;
				function animateConfetti() {
					cctx.clearRect(0, 0, cc.width, cc.height);
					let alive = false;
					particles.forEach(p => {
						if (p.life <= 0) return;
						alive = true;
						p.x += p.vx;
						p.vy += 0.12 * dpr;
						p.y += p.vy;
						p.rot += p.rv;
						p.life -= 0.006;
						cctx.save();
						cctx.translate(p.x, p.y);
						cctx.rotate(p.rot);
						cctx.globalAlpha = Math.max(0, p.life);
						cctx.fillStyle = p.color;
						cctx.fillRect(-p.size/2, -p.size/2, p.size, p.size * 0.6);
						cctx.restore();
					});
					if (alive && frame < 300) {
						frame++;
						requestAnimationFrame(animateConfetti);
					} else {
						cctx.clearRect(0, 0, cc.width, cc.height);
					}
				}
				animateConfetti();
			}

			// ── EVENT WIRING ──
			canvas.addEventListener('mousedown', onPointerDown);
			canvas.addEventListener('mousemove', onPointerMove);
			canvas.addEventListener('mouseup', onPointerUp);
			canvas.addEventListener('mouseleave', onPointerUp);
			canvas.addEventListener('touchstart', onPointerDown, { passive: false });
			canvas.addEventListener('touchmove', onPointerMove, { passive: false });
			canvas.addEventListener('touchend', onPointerUp);

			document.getElementById('start-btn').addEventListener('click', () => {
				document.getElementById('splash').style.display = 'none';
				document.getElementById('game-area').style.display = 'flex';
				loadLevel(0);
			});

			document.getElementById('reset-btn').addEventListener('click', () => {
				loadLevel(currentLevel);
			});

			document.getElementById('menu-btn').addEventListener('click', () => {
				document.getElementById('game-area').style.display = 'none';
				document.getElementById('win-overlay').classList.remove('show');
				document.getElementById('splash').style.display = 'flex';
			});

			document.getElementById('next-btn').addEventListener('click', () => {
				if (currentLevel >= LEVELS.length - 1) {
					document.getElementById('win-overlay').classList.remove('show');
					document.getElementById('game-area').style.display = 'none';
					document.getElementById('all-done').classList.add('show');
					fireConfetti();
					setTimeout(fireConfetti, 800);
					setTimeout(fireConfetti, 1600);
				} else {
					loadLevel(currentLevel + 1);
				}
			});

			document.getElementById('replay-btn').addEventListener('click', () => {
				loadLevel(currentLevel);
			});

			document.getElementById('restart-all-btn').addEventListener('click', () => {
				document.getElementById('all-done').classList.remove('show');
				document.getElementById('game-area').style.display = 'flex';
				loadLevel(0);
			});

			window.addEventListener('resize', () => {
				if (document.getElementById('game-area').style.display !== 'none') {
					sizeCanvas();
					draw();
				}
			});
		})();
		</script>
	</body>
</html>
